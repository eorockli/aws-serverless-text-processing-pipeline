{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3SendMessage",
      "Effect": "Allow",
      "Principal": {
        "Service": "s3.amazonaws.com"
      },
      "Action": "sqs:SendMessage",
      "Resource": "arn:aws:sqs:eu-west-1:578761488692:text-processing-queue", # replace
      "Condition": {
        "ArnEquals": {
          "aws:SourceArn": "arn:aws:s3:::eyong-file-upload-bucket" # replace
        }
      }
    }
  ]
}
